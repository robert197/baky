# Django
DJANGO_SETTINGS_MODULE=baky.settings.local
SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Docker provides this)
DATABASE_URL=postgres://baky:baky@db:5432/baky

# File Storage (S3/R2 - not needed for local dev, uses filesystem)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=baky-uploads
AWS_S3_REGION_NAME=eu-central-1

# Email (not needed for local dev, Mailpit catches all email)
EMAIL_API_KEY=

# Encryption (for apartment access codes)
ENCRYPTION_KEY=change-me-to-a-random-string

# Redis (Docker provides this)
REDIS_URL=redis://redis:6379/0

# Demo accounts (created by `make seed`)
# Owner: demo-owner@baky.at / demo1234
# Inspector: demo-inspector@baky.at / demo1234
# Admin: admin@baky.at / admin1234
