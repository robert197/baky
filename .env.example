# =============================================================================
# BAKY Environment Configuration
# For local dev: cp .env.example .env (defaults work with Docker Compose)
# For production: cp .env.example .env.production (fill in all values)
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Not required for local dev (local.py provides a default).
SECRET_KEY=

# Set to True for development, False for production
DEBUG=True

# Comma-separated list of hostnames
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Which settings module to use
# DJANGO_SETTINGS_MODULE=baky.settings.local

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string. Falls back to SQLite in local dev.
# Docker default (set in docker-compose.yml): postgres://baky:baky@db:5432/baky
# DATABASE_URL=postgres://baky:baky@localhost:5432/baky

# -----------------------------------------------------------------------------
# CSRF (Production only — must include https:// scheme)
# -----------------------------------------------------------------------------
# CSRF_TRUSTED_ORIGINS=https://baky.at,https://www.baky.at

# -----------------------------------------------------------------------------
# Encrypted Fields (Production only)
# -----------------------------------------------------------------------------
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FIELD_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Storage (AWS S3 / Cloudflare R2) — Production only
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=baky-media
# AWS_S3_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
# AWS_S3_CUSTOM_DOMAIN=cdn.baky.at

# -----------------------------------------------------------------------------
# Email (Resend) — Production only
# -----------------------------------------------------------------------------
# RESEND_API_KEY=
# SITE_URL=https://baky.at

# -----------------------------------------------------------------------------
# Error Tracking (Sentry) — Production only, optional
# Leave SENTRY_DSN empty to disable
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Gunicorn — Production only
# -----------------------------------------------------------------------------
# WEB_CONCURRENCY=5
# GUNICORN_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Build-time (set in CI, not in .env files)
# -----------------------------------------------------------------------------
# GIT_SHA=

# -----------------------------------------------------------------------------
# PostgreSQL (for docker-compose db service)
# -----------------------------------------------------------------------------
POSTGRES_DB=baky
POSTGRES_USER=baky
POSTGRES_PASSWORD=baky

# -----------------------------------------------------------------------------
# Google Maps (optional, client-side key)
# -----------------------------------------------------------------------------
# GOOGLE_MAPS_API_KEY=
